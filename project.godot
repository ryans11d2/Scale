[application]

config/name="Scale"
run/main_scene="uid://b4nrtg2gqy7o"
config/use_custom_user_dir=true
config/custom_user_dir_name="save"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://Sprites/Scale_Game_Icon.png"

[autoload]

